{
  "name": "@multi-functional-agent/playwright-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright MCP server for web-buddy browser automation",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "playwright-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\"",
    "start": "node ./dist/server.js",
    "dev": "npm run build && npm start",
    "test:smoke": "npm run build && node ./scripts/smoke-test.mjs",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.52.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  }
}

{
  "name": "@multi-functional-agent/web-buddy",
  "version": "0.1.0",
  "private": true,
  "description": "Web Buddy — local Web Agent runtime + Playwright browser tools + MCP server",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "web-buddy-mcp": "dist/server.js",
    "playwright-mcp": "dist/server.js",
    "web-agent": "dist/cli/demo.js",
    "job-agent": "dist/cli/demo.js",
    "web-agent-web": "dist/web/server.js",
    "job-agent-web": "dist/web/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\"",
    "start": "node ./dist/server.js",
    "dev": "npm run build && npm start",
    "demo": "npm run build && node ./dist/cli/demo.js demo-form --headful",
    "demo:form": "npm run build && node ./dist/cli/demo.js demo-form --headful",
    "demo:research": "npm run build && node ./dist/cli/demo.js demo-research --headless",
    "demo:auto": "npm run build && node ./dist/cli/demo.js demo-form --headless --auto-gate",
    "demo:match": "npm run build && node ./dist/cli/demo.js match --headful",
    "alibaba:apply": "npm run build && npm --prefix ../claude-code run build && node ./scripts/adapters/claude-code/alibaba-apply.mjs",
    "alibaba:apply:raw": "npm run build && node ./dist/cli/demo.js alibaba-apply --headful",
    "alibaba:claude": "npm run build && npm --prefix ../claude-code run build && node ./scripts/adapters/claude-code/alibaba-apply.mjs",
    "fill": "npm run build && node ./dist/cli/demo.js fill",
    "login": "npm run build && node ./dist/cli/demo.js login",
    "web": "npm run build && npm --prefix ../claude-code run build && node ./dist/web/server.js",
    "test:e2e-auto-apply": "npm run build && node ./scripts/e2e-auto-apply.mjs",
    "test:e2e-web-auto-apply": "npm run build && node ./scripts/e2e-web-auto-apply.mjs",
    "test:smoke": "npm run build && node ./scripts/smoke-test.mjs",
    "test:resume": "node ./scripts/resume-test.mjs",
    "test:matcher": "node ./scripts/matcher-test.mjs",
    "test:agent-loop": "node ./scripts/agent-loop-test.mjs",
    "test:agent-runtime": "node ./scripts/agent-runtime-test.mjs",
    "test:kernel": "npm run build && node ./scripts/agent-kernel-test.mjs",
    "test:trace-inputs": "npm run build && node ./scripts/trace-inputs-test.mjs",
    "test:metrics": "npm run build && node ./scripts/metrics-test.mjs",
    "test:tool-execution": "npm run build && node ./scripts/tool-execution-test.mjs",
    "test:policy": "npm run build && node ./scripts/policy-decision-test.mjs",
    "test:policy-engine": "npm run build && node ./scripts/policy-engine-test.mjs",
    "test:tool-catalog": "npm run build && node ./scripts/tool-catalog-test.mjs",
    "test:observation": "npm run build && node ./scripts/observation-test.mjs",
    "test:context": "npm run build && node ./scripts/context-manager-test.mjs",
    "test:prompt-sections": "npm run build && node ./scripts/prompt-sections-test.mjs",
    "test:workflow": "npm run build && node ./scripts/workflow-state-test.mjs && node ./scripts/workflow-transition-test.mjs",
    "test:agent-runtime-workflow": "npm run build && node ./scripts/agent-runtime-workflow-test.mjs",
    "test:safety-report": "npm run build && node ./scripts/safety-report-test.mjs",
    "test:session": "npm run build && node ./scripts/session-store-test.mjs && node ./scripts/session-runtime-smoke-test.mjs",
    "test:mvp": "npm run build && npm run test:context && npm run test:prompt-sections && npm run test:metrics && npm run test:tool-execution && npm run test:policy && npm run test:policy-engine && npm run test:workflow && npm run test:agent-runtime && npm run test:kernel && npm run test:agent-runtime-workflow && npm run test:agent-loop && npm run test:session && npm run benchmark:simple && npm run benchmark:complex && npm run benchmark:research && npm run test:tool-catalog && npm run test:observation && npm run test:safety-report",
    "test:alibaba-probe": "node ./scripts/alibaba-application-probe.mjs",
    "benchmark:simple": "npm run build && node ./scripts/benchmark-simple.mjs",
    "benchmark:complex": "npm run build && node ./scripts/benchmark-complex.mjs",
    "benchmark:research": "npm run build && node ./scripts/benchmark-research.mjs",
    "report:safety": "npm run build && node ./scripts/safety-report.mjs",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pdfjs-dist": "^4.10.38",
    "playwright": "^1.52.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  }
}

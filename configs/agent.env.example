# ── job-agent SDK configuration ──────────────────────────────────────
# Copy to the repo root as `.env` (or export these in your shell).
# Everything here is OPTIONAL — but `fill` / `alibaba-apply` need a model key.

# ── Model ────────────────────────────────────────────────────────────
# Two wire formats are supported. Set ONE block.
#
# (A) Anthropic-compatible — e.g. Zhipu GLM (open.bigmodel.cn), real Anthropic.
#     The agent auto-detects this when ANTHROPIC_AUTH_TOKEN is set. GLM's
#     Anthropic-compat API lives under /api/anthropic (auto-appended for
#     open.bigmodel.cn). Verified end-to-end with glm-4.7 + tool-calling.
ANTHROPIC_BASE_URL=https://open.bigmodel.cn
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=glm-4.7
# ANTHROPIC_API_BASE=  # override the full messages base if needed
#
# (B) OpenAI-compatible — OpenAI, Azure, DeepSeek, Ollama openai shim, ...
#     Uncomment to use instead. Must support function/tool-calling.
# MODEL_API_KEY=
# MODEL_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# ── Resume ───────────────────────────────────────────────────────────
# .pdf (parsed with pdfjs-dist), .json (already-structured), or .txt.
# If absent, a sample resume is generated at run time.
RESUME_PDF_PATH=tmp/pdfs/resume.pdf

# ── Cookie login (storageState) ──────────────────────────────────────
# Path to a saved Playwright storageState (cookies + localStorage).
# Empty → derived per host as output/auth/<host>.json.
# Run `job-agent login <url>` once to create it; then `fill` reuses it.
PLAYWRIGHT_STORAGE_STATE=

# ── Alibaba careers (match / alibaba-apply presets) ──────────────────
ALIBABA_CAREERS_URL=https://talent-holding.alibaba.com/off-campus/position-list?lang=zh
ALIBABA_PROBE_JOB_TITLE=
AGENT_MAX_JOBS_TO_DETAIL=3

# ── Agent loop ───────────────────────────────────────────────────────
# Max LLM reasoning steps per fill run.
AGENT_MAX_STEPS=50

# ── Browser / visualization ──────────────────────────────────────────
# PLAYWRIGHT_HEADLESS=false shows the Chromium window so you can watch
# mouse moves, click highlighting, and the fill process.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_VISUAL_HIGHLIGHT=true
PLAYWRIGHT_KEEP_BROWSER_OPEN=false
PLAYWRIGHT_TYPE_DELAY_MS=12
PLAYWRIGHT_SLOWMO_MS=80
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=90000
PLAYWRIGHT_ACTION_TIMEOUT_MS=20000
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=840

# ── Safety / policy ──────────────────────────────────────────────────
# Allowlist for navigation; empty = same-origin only.
PLAYWRIGHT_ALLOWED_DOMAINS=talent-holding.alibaba.com
PLAYWRIGHT_BLOCK_LOCALHOST=true
# 'cli' prompts y/n/m at each gate; 'auto' hands off the 5 sensitive gates.
HUMAN_GATE_MODE=cli

# ── Trace ────────────────────────────────────────────────────────────
TRACE_OUT_DIR=output
